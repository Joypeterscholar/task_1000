{
  "info": {
    "name": "Simple Books API",
    "_postman_id": "simple-books-v2",
    "description": "Import into Postman. Set base_url variable. Run top to bottom.\n\nNewman CLI:\n  npm install -g newman newman-reporter-htmlextra\n  newman run postman/simple-books.postman_collection.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4004" },
    { "key": "book_id",  "value": "" }
  ],
  "item": [
    {
      "name": "1 — GET /health",
      "request": { "method": "GET", "url": "{{base_url}}/health" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200 ok', () => pm.response.to.have.status(200));",
        "pm.test('status is ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
      ]}}]
    },
    {
      "name": "2 — GET /api/books",
      "request": { "method": "GET", "url": "{{base_url}}/api/books" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "pm.test('data is array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
      ]}}]
    },
    {
      "name": "3 — GET /api/books/1",
      "request": { "method": "GET", "url": "{{base_url}}/api/books/1" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "pm.test('id is 1', () => pm.expect(pm.response.json().data.id).to.eql('1'));"
      ]}}]
    },
    {
      "name": "4 — GET /api/books/999 (404)",
      "request": { "method": "GET", "url": "{{base_url}}/api/books/999" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('404', () => pm.response.to.have.status(404));"
      ]}}]
    },
    {
      "name": "5 — POST /api/books (create)",
      "request": {
        "method": "POST", "url": "{{base_url}}/api/books",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Arrow of God\",\n  \"author\": \"Chinua Achebe\",\n  \"genre\": \"Fiction\",\n  \"year\": 1964\n}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('201 created', () => pm.response.to.have.status(201));",
        "pm.test('has id', () => {",
        "  const id = pm.response.json().data.id;",
        "  pm.expect(id).to.be.a('string');",
        "  pm.collectionVariables.set('book_id', id);",
        "});"
      ]}}]
    },
    {
      "name": "6 — POST /api/books (400 missing title)",
      "request": {
        "method": "POST", "url": "{{base_url}}/api/books",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"author\":\"No Title\"}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('400', () => pm.response.to.have.status(400));"
      ]}}]
    },
    {
      "name": "7 — PUT /api/books/:id (update)",
      "request": {
        "method": "PUT", "url": "{{base_url}}/api/books/{{book_id}}",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Arrow of God (Revised)\",\n  \"author\": \"Chinua Achebe\",\n  \"genre\": \"Classic Fiction\",\n  \"year\": 1964\n}" }
      },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200', () => pm.response.to.have.status(200));",
        "pm.test('title updated', () => pm.expect(pm.response.json().data.title).to.include('Revised'));"
      ]}}]
    },
    {
      "name": "8 — DELETE /api/books/:id",
      "request": { "method": "DELETE", "url": "{{base_url}}/api/books/{{book_id}}" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('200 deleted', () => pm.response.to.have.status(200));",
        "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);"
      ]}}]
    },
    {
      "name": "9 — DELETE /api/books/999 (404)",
      "request": { "method": "DELETE", "url": "{{base_url}}/api/books/999" },
      "event": [{ "listen": "test", "script": { "exec": [
        "pm.test('404', () => pm.response.to.have.status(404));"
      ]}}]
    }
  ]
}
